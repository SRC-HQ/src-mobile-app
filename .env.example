# Environment Configuration Example
# Copy this file to .env and fill in your values

# Solana Network: devnet | testnet | mainnet-beta | localnet
EXPO_PUBLIC_SOLANA_NETWORK=devnet

# Solana RPC Endpoint
EXPO_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com

# App Environment: development | devnet | mainnet
EXPO_PUBLIC_APP_ENV=development

# Backend API URL
EXPO_PUBLIC_API_URL=https://api.spermrace.club

# WebSocket URL for game server
EXPO_PUBLIC_WS_URL=wss://api.spermrace.club/game

# Solana Program ID (Public Key)
EXPO_PUBLIC_PROGRAM_ID=2y2AdrVLKqwcA5GQEC1ULEHac3hH9ck565UBqzPaReJZ

# Optional: Custom RPC URL (overrides EXPO_PUBLIC_RPC_ENDPOINT)
# EXPO_PUBLIC_SOLANA_RPC_URL=https://your-custom-rpc.com
