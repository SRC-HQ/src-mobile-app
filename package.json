{
  "name": "src-mobile-app",
  "scripts": {
    "android": "expo run:android",
    "android:build": "expo prebuild -p android",
    "android:devnet": "EXPO_PUBLIC_SOLANA_NETWORK=devnet expo run:android",
    "android:mainnet": "EXPO_PUBLIC_SOLANA_NETWORK=mainnet-beta expo run:android",
    "android:local": "cp .env.local .env && expo run:android",
    "build": "tsc --project tsconfig.build.json && npm run android:build",
    "ci": "tsc --project tsconfig.build.json && npm run lint:check && npm run fmt:check && npm run android:build",
    "dev": "expo start --clear --dev-client --reset-cache",
    "dev:devnet": "EXPO_PUBLIC_SOLANA_NETWORK=devnet expo start --clear --dev-client",
    "dev:mainnet": "EXPO_PUBLIC_SOLANA_NETWORK=mainnet-beta expo start --clear --dev-client",
    "dev:local": "cp .env.local .env && expo start --clear --dev-client",
    "doctor": "npx -y expo-doctor@latest",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "ios": "expo run:ios",
    "ios:devnet": "EXPO_PUBLIC_SOLANA_NETWORK=devnet expo run:ios",
    "ios:mainnet": "EXPO_PUBLIC_SOLANA_NETWORK=mainnet-beta expo run:ios",
    "ios:local": "cp .env.local .env && expo run:ios",
    "lint": "expo lint --fix",
    "lint:check": "expo lint",
    "start": "expo start",
    "typecheck": "tsc --project tsconfig.build.json --noEmit",
    "web": "expo start --web"
  },
  "displayName": "Sperm Race",
  "description": "A Solana mobile racing app with Expo, React Native, and Uniwind.",
  "usecase": "Mobile",
  "keywords": [
    "expo",
    "mobile-wallet-adapter",
    "react-native",
    "solana-kit",
    "uniwind",
    "tailwind"
  ],
  "main": "./index.js",
  "version": "1.0.0",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@expo-google-fonts/orbitron": "^0.4.2",
    "@expo-google-fonts/space-mono": "^0.4.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@solana-mobile/mobile-wallet-adapter-protocol": "^2.1.3",
    "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.1.3",
    "@solana/kit": "^5.5.0",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.90.21",
    "@wallet-ui/react-native-kit": "^3.2.0",
    "buffer": "^6.0.3",
    "expo": "~54.0.22",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "^6.0.20",
    "expo-font": "^14.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.14",
    "expo-status-bar": "~3.0.8",
    "heroui-native": "^1.0.0-rc.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-nitro-modules": "^0.33.9",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-quick-crypto": "^1.0.7",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.9.0",
    "react-native-worklets": "^0.7.4",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "~4.1.16",
    "uniwind": "^1.3.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
