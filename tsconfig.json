{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "*.ts",
    "*.tsx"
  ],
  "exclude": [
    "node_modules",
    "src-monorepo/**/*",
    "android",
    "ios",
    ".expo",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
